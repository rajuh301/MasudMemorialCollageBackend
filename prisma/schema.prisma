generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password           String
  role               UserRole
  needPasswordChange Boolean    @default(true)
  status             UserStatus @default(ACTIVE)
  contactNumber      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin   Admin?
  teacher Teacher?
  student Student?

  @@map("users")
}

model Admin {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  profilePhoto  String?
  contactNumber String
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdTeachers Teacher[] @relation("AdminToTeacher")

  @@map("admins")
}

model Teacher {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  profilePhoto  String?
  contactNumber String
  joiningDate   DateTime
  address       String

  createdById String
  createdBy   Admin? @relation("AdminToTeacher", fields: [createdById], references: [id])

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdStudents Student[] @relation("TeacherToStudent")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("teachers")
}

model Student {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone        String
  profilePhoto String?
  isDeleted    Boolean @default(false)

  teacherCreatedById String?
  teacherCreatedBy   Teacher? @relation("TeacherToStudent", fields: [teacherCreatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  results Result[]

  @@map("students")
}

model Result {
  id           String @id @default(uuid())
  studentId    String
  departmentId String

  marks Float
  grade String

  student    Student    @relation(fields: [studentId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
}

model Department {
  id   String @id @default(uuid())
  name String
  year String

  results          Result[]
  StudentAdmission StudentAdmission[]
}

model StudentAdmission {
  id               String        @id @default(uuid())
  firstName        String
  lastName         String
  email            String?       @unique
  phone            String
  dateOfBirth      DateTime
  gender           Gender
  bloodGroup       BloodGroup
  maritalStatus    MaritalStatus
  presentAddress   String
  permanentAddress String

  guardianName     String
  guardianPhone    String
  guardianRelation String

  previousSchool String
  previousGPA    Float
  passingYear    Int

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  subjects String[]

  admissionDate DateTime @default(now())

  admissionFee  Float?
  paymentStatus PaymentStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     String?

  @@map("student_admissions")
}

model Banner {
  id String @id @default(uuid())

  title       String
  subTitle    String
  description String
  image       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean @default(false)

  @@map("banners")
}

model SubBanner {
  id String @id @default(uuid())

  title       String
  subTitle    String
  description String
  image       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subBanners")
}

model Notice {
  id String @id @default(uuid())

  title          String
  description    String
  isImportant    Boolean
  isRecentNotice Boolean
  date           DateTime

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notices")
}

model Event {
  id String @id @default(uuid())

  title       String
  description String
  location    String
  date        DateTime
  image       String?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

model StudentsComment {
  id String @id @default(uuid())

  name        String
  description String
  batch       String
  image       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("studentsComments")
}

model OurTeachers {
  id String @id @default(uuid())

  name        String
  position    String
  subject     String
  description String
  rating      String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  image       String?

  @@map("ourTeachers")
}

model Contact {
  id String @id @default(uuid())

  name    String
  email   String
  comment String

  phone String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum Gender {
  MALE
  FEMALE
}

enum BloodGroup {
  A_POSITIVE
  B_POSITIVE
  O_POSITIVE
  AB_POSITIVE
  A_NEGATIVE
  B_NEGATIVE
  O_NEGATIVE
  AB_NEGATIVE
}

enum MaritalStatus {
  MARRIED
  UNMARRIED
}
